{
  "info": {
    "_postman_id": "b1c0ffee-0000-4a00-8000-workoutapi001",
    "name": "workout-api (local)",
    "description": "Local manual tests for workout-api.\n\nSetup: run `supabase start` and `./gradlew bootRun` first.\n1) Run **Auth -> Sign in** once. Its test script stores `access_token` as a collection variable.\n2) **API -> GET /api/me** then uses that token automatically (collection-level Bearer auth).\n\nEdit values under the collection's Variables tab. The apikey/password are local Supabase dev defaults (not real secrets).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [ { "key": "token", "value": "{{access_token}}", "type": "string" } ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "supabaseUrl", "value": "http://127.0.0.1:54321" },
    { "key": "apikey", "value": "sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH" },
    { "key": "email", "value": "dev@workout.test" },
    { "key": "password", "value": "password123" },
    { "key": "access_token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign in (mint + store token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) { pm.collectionVariables.set('access_token', res.access_token); }",
                  "pm.test('got an access_token', function () { pm.expect(res.access_token, 'access_token').to.be.a('string'); });"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "apikey", "value": "{{apikey}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{supabaseUrl}}/auth/v1/token?grant_type=password",
              "host": [ "{{supabaseUrl}}" ],
              "path": [ "auth", "v1", "token" ],
              "query": [ { "key": "grant_type", "value": "password" } ]
            },
            "description": "Signs in dev@workout.test against local Supabase Auth and stores the access_token."
          }
        },
        {
          "name": "Sign up (create user, first run only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) { pm.collectionVariables.set('access_token', res.access_token); }"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "apikey", "value": "{{apikey}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{supabaseUrl}}/auth/v1/signup",
              "host": [ "{{supabaseUrl}}" ],
              "path": [ "auth", "v1", "signup" ]
            },
            "description": "Creates the dev user (local stack auto-confirms). Skip if it already exists."
          }
        }
      ]
    },
    {
      "name": "API",
      "item": [
        {
          "name": "Health (public, no auth)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": [ "{{baseUrl}}" ],
              "path": [ "actuator", "health" ]
            }
          }
        },
        {
          "name": "GET /api/me (authenticated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('returns userId', function () { pm.expect(pm.response.json()).to.have.property('userId'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/me",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "me" ]
            },
            "description": "Uses the collection Bearer auth ({{access_token}}). Run 'Sign in' first."
          }
        },
        {
          "name": "GET /api/me (no token -> 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 401', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/me",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "me" ]
            },
            "description": "No Authorization header - expect 401."
          }
        }
      ]
    }
  ]
}
