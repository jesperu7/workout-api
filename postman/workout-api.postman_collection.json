{
  "info": {
    "_postman_id": "b1c0ffee-0000-4a00-8000-workoutapi001",
    "name": "workout-api (local)",
    "description": "Local manual tests for workout-api.\n\nSetup: run `supabase start` and `./gradlew bootRun` first.\n\nHappy path (run top to bottom): Auth > Sign in, then Exercises > List (saves exerciseId), Workouts > Create (saves workoutId), Workout exercises > Add (saves workoutExerciseId), Sets > Log (saves setId). Later requests reuse those saved ids automatically.\n\nv1.1: Exercises > 'Search exercises by name' and 'Create my exercise' cover user-created exercises (per-user unique names; duplicate -> 409; private to their owner).\n\nThe apikey/password are local Supabase dev defaults (not real secrets). The set body must match the exercise's measurement type (e.g. weight+reps for Bench Press).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [ { "key": "token", "value": "{{access_token}}", "type": "string" } ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "supabaseUrl", "value": "http://127.0.0.1:54321" },
    { "key": "apikey", "value": "sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH" },
    { "key": "email", "value": "dev@workout.test" },
    { "key": "password", "value": "password123" },
    { "key": "access_token", "value": "" },
    { "key": "guest_token", "value": "" },
    { "key": "exerciseId", "value": "" },
    { "key": "myExerciseId", "value": "" },
    { "key": "workoutId", "value": "" },
    { "key": "workoutExerciseId", "value": "" },
    { "key": "setId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign in (mint + store token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) { pm.collectionVariables.set('access_token', res.access_token); }",
                  "pm.test('got an access_token', function () { pm.expect(res.access_token, 'access_token').to.be.a('string'); });"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "apikey", "value": "{{apikey}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": {
              "raw": "{{supabaseUrl}}/auth/v1/token?grant_type=password",
              "host": [ "{{supabaseUrl}}" ],
              "path": [ "auth", "v1", "token" ],
              "query": [ { "key": "grant_type", "value": "password" } ]
            },
            "description": "Signs in dev@workout.test against local Supabase Auth and stores the access_token."
          }
        },
        {
          "name": "Sign in as GUEST (anonymous, stores guest_token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) { pm.collectionVariables.set('guest_token', res.access_token); }",
                  "pm.test('got a guest access_token', function () { pm.expect(res.access_token, 'access_token').to.be.a('string'); });"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "apikey", "value": "{{apikey}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{supabaseUrl}}/auth/v1/signup", "host": [ "{{supabaseUrl}}" ], "path": [ "auth", "v1", "signup" ] },
            "description": "[v1.1] An EMPTY signup body performs an anonymous sign-in (what supabase-js signInAnonymously() calls). Needs enable_anonymous_sign_ins = true in supabase/config.toml and a restarted stack. Every run creates a brand-new guest auth.users row. The token carries is_anonymous=true, which the backend maps to ROLE_GUEST."
          }
        },
        {
          "name": "Sign up (create user, first run only)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "apikey", "value": "{{apikey}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{supabaseUrl}}/auth/v1/signup", "host": [ "{{supabaseUrl}}" ], "path": [ "auth", "v1", "signup" ] },
            "description": "Creates the dev user (local stack auto-confirms). Skip if it already exists."
          }
        }
      ]
    },
    {
      "name": "Health & Me",
      "item": [
        {
          "name": "Health (public, no auth)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/actuator/health", "host": [ "{{baseUrl}}" ], "path": [ "actuator", "health" ] }
          }
        },
        {
          "name": "GET /api/me (authenticated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/me", "host": [ "{{baseUrl}}" ], "path": [ "api", "me" ] }
          }
        },
        {
          "name": "GET /api/me (no token -> 401)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/me", "host": [ "{{baseUrl}}" ], "path": [ "api", "me" ] }
          }
        }
      ]
    },
    {
      "name": "Exercises",
      "item": [
        {
          "name": "List exercises (saves exerciseId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const arr = pm.response.json().items;",
                  "const chosen = arr.find(e => e.name === 'Bench Press') || arr[0];",
                  "if (chosen) { pm.collectionVariables.set('exerciseId', chosen.id); }",
                  "pm.test('catalog is non-empty', function () { pm.expect(arr.length).to.be.above(0); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/exercises", "host": [ "{{baseUrl}}" ], "path": [ "api", "exercises" ] },
            "description": "Lists the global catalog and stores Bench Press (or the first result) as exerciseId."
          }
        },
        {
          "name": "List exercises (filter by type)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/exercises?measurementType=WEIGHT_REPS&limit=50&offset=0",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "exercises" ],
              "query": [
                { "key": "measurementType", "value": "WEIGHT_REPS" },
                { "key": "category", "value": "push", "disabled": true },
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Search exercises by name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/exercises?name=press",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "exercises" ],
              "query": [ { "key": "name", "value": "press" } ]
            },
            "description": "Case-insensitive substring search over global + my own exercises ('press' matches 4 seeded globals). The client should search before offering 'create new'."
          }
        },
        {
          "name": "Get exercise by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/exercises/{{exerciseId}}", "host": [ "{{baseUrl}}" ], "path": [ "api", "exercises", "{{exerciseId}}" ] }
          }
        },
        {
          "name": "Exercise history (over time · ?weight= · ?reps=)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/exercises/{{exerciseId}}/history",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "exercises", "{{exerciseId}}", "history" ],
              "query": [
                { "key": "weight", "value": "100", "disabled": true },
                { "key": "reps", "value": "5", "disabled": true }
              ]
            },
            "description": "The headline bidirectional-history feature, scoped to the caller's own sets. Three modes:\n- no params -> all sets for the exercise, over time;\n- enable ?weight=100 -> reps achieved at that weight, over time;\n- enable ?reps=5 -> weight used at that rep count, over time.\nUses {{exerciseId}} (saved by 'List exercises' = Bench Press). Run scripts/seed-demo-data.sh first so there's data to return. Returns a plain array of points (performedAt + measurement fields)."
          }
        },
        {
          "name": "Create my exercise (saves myExerciseId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('created (201) or already exists from an earlier run (409)', function () { pm.expect([201, 409]).to.include(pm.response.code); });",
                  "const res = pm.response.json();",
                  "if (res.id) { pm.collectionVariables.set('myExerciseId', res.id); }",
                  "if (pm.response.code === 201) { pm.test('owned, not global', function () { pm.expect(res.global).to.eql(false); }); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Postman Crossover\",\n  \"category\": \"push\",\n  \"measurementType\": \"WEIGHT_REPS\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/exercises", "host": [ "{{baseUrl}}" ], "path": [ "api", "exercises" ] },
            "description": "[v1.1] Creates a user-owned exercise; the owner comes from the JWT, never the body. Names are unique per user (case-insensitive), so re-running returns 409 problem+json — that's the V3 partial unique index at work. Reusing a global name like 'Bench Press' IS allowed (shadowing); only your own names collide. The new exercise is invisible to other users."
          }
        },
        {
          "name": "Create exercise as GUEST (-> 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('guests are read+log only', function () { pm.response.to.have.status(403); });"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{guest_token}}", "type": "string" } ] },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Guest Move\",\n  \"measurementType\": \"BODYWEIGHT\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/exercises", "host": [ "{{baseUrl}}" ], "path": [ "api", "exercises" ] },
            "description": "[v1.1] Run Auth > 'Sign in as GUEST' first. Anonymous tokens map to ROLE_GUEST, and POST /api/exercises requires ROLE_MEMBER -> 403 problem+json. Guests can still browse the catalog and log workouts/sets."
          }
        }
      ]
    },
    {
      "name": "Workouts",
      "item": [
        {
          "name": "Create workout (saves workoutId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('created', function () { pm.response.to.have.status(201); });",
                  "const id = pm.response.json().id;",
                  "if (id) { pm.collectionVariables.set('workoutId', id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"Postman session\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/workouts", "host": [ "{{baseUrl}}" ], "path": [ "api", "workouts" ] },
            "description": "performedAt is optional (defaults to now). Stores the new id as workoutId."
          }
        },
        {
          "name": "List my workouts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/workouts?limit=50&offset=0",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "workouts" ],
              "query": [ { "key": "limit", "value": "50" }, { "key": "offset", "value": "0" } ]
            }
          }
        },
        {
          "name": "Get workout by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/workouts/{{workoutId}}", "host": [ "{{baseUrl}}" ], "path": [ "api", "workouts", "{{workoutId}}" ] }
          }
        },
        {
          "name": "Update workout (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"updated from Postman\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/workouts/{{workoutId}}", "host": [ "{{baseUrl}}" ], "path": [ "api", "workouts", "{{workoutId}}" ] }
          }
        },
        {
          "name": "Delete workout",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/workouts/{{workoutId}}", "host": [ "{{baseUrl}}" ], "path": [ "api", "workouts", "{{workoutId}}" ] },
            "description": "Cascades to its workout-exercises and sets. Expect 204."
          }
        }
      ]
    },
    {
      "name": "Workout exercises",
      "item": [
        {
          "name": "Add exercise to workout (saves workoutExerciseId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('created', function () { pm.response.to.have.status(201); });",
                  "const id = pm.response.json().id;",
                  "if (id) { pm.collectionVariables.set('workoutExerciseId', id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"exerciseId\": \"{{exerciseId}}\",\n  \"notes\": \"top set\"\n}", "options": { "raw": { "language": "json" } } },
            "url": {
              "raw": "{{baseUrl}}/api/workouts/{{workoutId}}/exercises",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "workouts", "{{workoutId}}", "exercises" ]
            }
          }
        },
        {
          "name": "List exercises in workout",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/workouts/{{workoutId}}/exercises",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "workouts", "{{workoutId}}", "exercises" ]
            }
          }
        },
        {
          "name": "Update workout-exercise (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"position\": 2,\n  \"notes\": \"moved\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/workout-exercises/{{workoutExerciseId}}", "host": [ "{{baseUrl}}" ], "path": [ "api", "workout-exercises", "{{workoutExerciseId}}" ] }
          }
        },
        {
          "name": "Delete workout-exercise",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/workout-exercises/{{workoutExerciseId}}", "host": [ "{{baseUrl}}" ], "path": [ "api", "workout-exercises", "{{workoutExerciseId}}" ] }
          }
        }
      ]
    },
    {
      "name": "Sets",
      "item": [
        {
          "name": "Log a set (saves setId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('created', function () { pm.response.to.have.status(201); });",
                  "const id = pm.response.json().id;",
                  "if (id) { pm.collectionVariables.set('setId', id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"weight\": 100,\n  \"reps\": 5,\n  \"rpe\": 8\n}", "options": { "raw": { "language": "json" } } },
            "url": {
              "raw": "{{baseUrl}}/api/workout-exercises/{{workoutExerciseId}}/sets",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "workout-exercises", "{{workoutExerciseId}}", "sets" ]
            },
            "description": "Body must match the exercise's measurement type. Bench Press is weight_reps => weight + reps (+ optional rpe). A bad combo returns 400."
          }
        },
        {
          "name": "Log an INVALID set (-> 400)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"reps\": 5\n}", "options": { "raw": { "language": "json" } } },
            "url": {
              "raw": "{{baseUrl}}/api/workout-exercises/{{workoutExerciseId}}/sets",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "workout-exercises", "{{workoutExerciseId}}", "sets" ]
            },
            "description": "weight_reps without weight -> 400 problem+json from MeasurementValidator."
          }
        },
        {
          "name": "List sets for a workout-exercise",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/workout-exercises/{{workoutExerciseId}}/sets",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "workout-exercises", "{{workoutExerciseId}}", "sets" ]
            }
          }
        },
        {
          "name": "Update set (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"reps\": 6\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/sets/{{setId}}", "host": [ "{{baseUrl}}" ], "path": [ "api", "sets", "{{setId}}" ] }
          }
        },
        {
          "name": "Delete set",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/sets/{{setId}}", "host": [ "{{baseUrl}}" ], "path": [ "api", "sets", "{{setId}}" ] }
          }
        }
      ]
    }
  ]
}
